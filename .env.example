# MapsProspector Pro — Exemplo de variáveis de ambiente
# Copie este arquivo para .env. Obrigatório apenas: banco de dados (DB_*).
# Chave da API de Busca: super admin cadastra no painel (Configurações).
# Chave da API de IA: super admin cadastra no painel (Configurações).
# ENCRYPTION_KEY: opcional; se não definir, o sistema gera em storage/encryption_key.

# Ambiente: development | production
ENVIRONMENT=development

# URL base da aplicação (com barra no final)
# Desenvolvimento: http://localhost/MapsProspector-Pro/
# Produção: https://seudominio.com/
BASE_URL=http://localhost/MapsProspector-Pro/

# Banco de dados — OBRIGATÓRIO (Hostinger: use os dados do painel MySQL)
DB_HOST=localhost
DB_NAME=maps
DB_USER=root
DB_PASS=

# Chave da API de Busca (Scraper/Apify) — opcional no .env; super admin cadastra no painel (Configurações)
SCRAPER_API_KEY=

# Chave da API de IA (OpenRouter) — opcional no .env; super admin cadastra no painel (Configurações)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-001

# Chave para criptografia do token do webhook — opcional; se vazio, o sistema gera em storage/encryption_key
# Para definir manualmente: openssl rand -base64 32
ENCRYPTION_KEY=

# Permitir exibição em iframe: 1 ou true = qualquer site; 0 = só mesma origem
ALLOW_IFRAME=1

# CORS: origem permitida em produção (ex.: https://seudominio.com)
# Deixe em branco para permitir qualquer origem
ALLOWED_ORIGIN=
